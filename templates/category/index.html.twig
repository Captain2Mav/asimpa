
{% extends 'base.html.twig' %}

{% block title %}Forum{% endblock %}

{% block body %}
<div class="forum-page">
    <section class="forum-hero container">
        <div class="forum-hero-box">
            <h1>Forum d'échange</h1>
            <p>
                Un espace pour poser vos questions, partager vos expériences
                et trouver des réponses selon vos besoins.
            </p>
        </div>
    </section>

    <section class="forum-categories container py-4">
        {% for category in categories %}
            <div class="forum-category-card mb-4">
                <div class="forum-category-header">
                    <div>
                        <h2>{{ category.name }}</h2>
                        <p>{{ category.description }}</p>
                    </div>
                    <span class="forum-category-pill">
                        {{ category.posts|length }} sujet{% if category.posts|length > 1 %}s{% endif %}
                    </span>
                </div>

                {% if category.posts|length > 0 %}
                    <div class="forum-topic-list">
                        {% for post in category.posts %}
                            <a href="{{ path('app_post_show', {'id': post.id}) }}" class="forum-topic-item">
                                <div class="forum-topic-main">
                                    <h3>{{ post.title }}</h3>
                                    <p>
                                        {{ post.content|striptags|slice(0, 90) }}{% if post.content|length > 90 %}...{% endif %}
                                    </p>
                                </div>
                                <div class="forum-topic-meta">
                                    <span class="forum-date">
                                        {% if post.createdAt is defined and post.createdAt %}
                                            {{ post.createdAt|date('d/m/Y') }}
                                        {% else %}
                                            Date indisponible
                                        {% endif %}
                                    </span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="forum-empty-state">
                        Aucun sujet pour le moment.
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </section>
</div>
{% endblock %} 
