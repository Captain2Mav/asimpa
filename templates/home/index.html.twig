{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<div class="home">

<!-- HERO -->
<section class="hero">
  <div class="container">
    <h1>Un accompagnement social qui vous redonne le pouvoir d’agir</h1>
    <p>
      Un service social indépendant, humain et personnalisé,
      pour vous accompagner avec écoute, clarté et confiance.
    </p>

    <div class="btn-center">
      <a href="{{ path('app_contact') }}" class="btn btn-main">
        Prendre rendez-vous
      </a>
    </div>
  </div>
</section>

<!-- PRESTATIONS -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Nos prestations</h2>

    <div class="row g-4">

      <!-- ENTREPRISES -->
      <div class="col-md-6">
        <div class="card-custom">
          <h5>Entreprises</h5>
          <p>Accompagnement social des salariés</p>

          <ul class="text-start">
            <li>Prévention des difficultés sociales</li>
            <li>Soutien dans les démarches</li>
          </ul>

          <div class="btn-center">
            <a href="{{ path('app_business') }}" class="btn btn-main">
              En savoir plus
            </a>
          </div>
        </div>
      </div>

      <!-- ASSOCIATIONS -->
      <div class="col-md-6">
        <div class="card-custom">
          <h5>Associations</h5>
          <p>Soutien aux structures associatives</p>

          <ul class="text-start">
            <li>Accompagnement administratif</li>
            <li>Orientation sociale</li>
          </ul>

          <div class="btn-center">
            <a href="{{ path('app_associations') }}" class="btn btn-main">
              En savoir plus
            </a>
          </div>
        </div>
      </div>

      <!-- ORGANISMES -->
      <div class="col-md-6">
        <div class="card-custom">
          <h5>Organismes publics/privés</h5>
          <p>Interventions sociales ponctuelles</p>

          <ul class="text-start">
            <li>Appui aux dispositifs</li>
            <li>Analyse des situations</li>
          </ul>

          <div class="btn-center">
            <a href="{{ path('app_organisme') }}" class="btn btn-main">
              En savoir plus
            </a>
          </div>
        </div>
      </div>

      <!-- PARTICULIERS -->
      <div class="col-md-6">
        <div class="card-custom">
          <h5>Particuliers</h5>
          <p>Accompagnement social personnalisé</p>

          <ul class="text-start">
            <li>Aide aux démarches</li>
            <li>Accès aux droits</li>
          </ul>

          <div class="btn-center">
            <a href="{{ path('app_particulier') }}" class="btn btn-main">
              En savoir plus
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- AVIS -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Avis clients</h2>

    <div class="row g-4">

      <div class="col-md-6">
        <div class="card-custom">
          <div class="stars">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>

          <p>Un accompagnement à l’écoute et humain</p>
          <strong>Mme Zadi</strong>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card-custom">
          <div class="stars">
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
            <i class="fa-solid fa-star"></i>
          </div>

          <p>Professionnelle et rassurante</p>
          <strong>Mme Kero</strong>
        </div>
      </div>

    </div>

    <div class="btn-center">
      <a href="{{ path('app_category') }}" class="btn btn-main">
        Voir tous les avis
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section text-center">
  <div class="container">
    <h2>Besoin d’un accompagnement personnalisé ?</h2>
    <p class="text-muted">
      Prenez contact dès aujourd’hui pour échanger en toute confidentialité
    </p>

    <div class="btn-center">
      <a href="{{ path('app_contact') }}" class="btn btn-main">
        Prendre rendez-vous
      </a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer bg-light">

  <div>
    <a href="{{ path('app_home') }}">Accueil</a>
    <a href="{{ path('app_category') }}">Forum</a>
    <a href="{{ path('app_contact') }}">Contact</a>
  </div>

  <div class="mt-2">
    <a href="{{ path('app_mentions') }}">Mentions légales</a>
    <a href="{{ path('app_privacy') }}">Politique de confidentialité</a>
  </div>

</footer>

</div>
{% endblock %} 
