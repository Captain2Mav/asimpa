{% extends 'base.html.twig' %}


{% block body %}
	<section class="d-flex align-items-center justify-content-center text-center bg-light" style="min-height: 90vh;">
		<div class="container">

			<h1 class="display-2 fw-bold mb-4">
				Un accompagnement social
				<span class="text-success">qui vous redonne le pouvoir d’agir</span>
			</h1>

			<p class="fs-4 mt-4 mb-4" style="max-width: 800px; margin: 0 auto; line-height: 1.6;">
				Un service social indépendant, humain et personnalisé,
				            pour vous accompagner avec écoute, clarté et confiance.
			</p>

			<a href="#" class="btn btn-success btn-lg px-5 py-3 shadow">
				Prendre rendez-vous
			</a>

		</div>
	</section>

	<section class="py-5">
		<div class="container">
			<h2 class="text-center mb-3">Nos Prestations</h2>

			<p class="text-center">Nous accompagnons différents publics dans leurs démarches sociales et économiques
			</p>

			<div class="row g-4">

				<div class="col-md-6">
					<div class="card h-100">
						<div class="card-body text-center">
							<h5 class="card-title">Entreprises</h5>
							<p>Accompagnement social des salariés</p>

							<ul class="text-start mx-auto" style="width: fit-content;">
								<li>Prévention des difficultés sociales</li>
								<li>Soutien dans les démarches</li>
							</ul>
							<a href="#" class="btn btn-primary mt-3">En savoir plus</a>
						</div>
					</div>
				</div>


				<div class="col-md-6">
					<div class="card h-100">
						<div class="card-body text-center">
							<h5 class="card-title">Associations</h5>
							<p>Soutien aux structures associatives</p>

							<ul class="text-start mx-auto" style="width: fit-content;">
								<li>Accompagnement administratif</li>
								<li>Orientation sociale</li>
							</ul>

							<a href="#" class="btn btn-primary">En savoir plus</a>
						
					           
									</div>
								</div>
							</div>

				<div class="col-md-6">
					<div class="card h-100">
						<div class="card-body text-center">
							<h5 class="card-title">Organismes publics /privés</h5>
							<p>Interventions sociales ponctuelles</p>

							<ul class="text-start mx-auto" style="width: fit-content;">
								<li>Appui aux dispositifs existants</li>
								<li>Analyse des situations</li>
							</ul>

							<a href="#" class="btn btn-primary">En savoir plus</a>
						
					           
									</div>
								</div>
							</div>

				<div class="col-md-6">
					<div class="card h-100">
						<div class="card-body text-center">
							<h5 class="card-title"> Particuliers</h5>
							<p>Accompagnement social personnalisé</p>

							<ul class="text-start mx-auto" style="width: fit-content;">
								<li>Aide aux démarches</li>
								<li>Accés aux droits</li>
							</ul>

							<a href="#" class="btn btn-primary">En savoir plus</a>
						
					           
									</div>
								</div>
							</div>


						</section>

					{% endblock %}
