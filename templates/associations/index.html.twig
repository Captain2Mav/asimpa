{% extends 'base.html.twig' %}

{% block title %}Associations{% endblock %}

{% block body %}
<div class="page-association">

    <!-- HERO -->
    <section class="hero-section bg-primary text-white text-center py-5">
        <div class="container">
            <h1 class="fw-bold mb-3">Un accompagnement social pour les associations</h1>
            <p class="mb-4">
                Soutenez vos actions, accompagnez vos bénéficiaires et apportez des solutions concrètes sur le terrain.
            </p>
            <a href="/contact" class="btn btn-light btn-lg">Prendre contact</a>
        </div>
    </section>

    <!-- PROBLÉMATIQUE -->
    <section class="py-5 text-center section-light">
        <div class="container">
            <h2 class="mb-4">Vos réalités de terrain</h2>

            <div class="pill-container">
                <span class="pill">Manque de temps</span>
                <span class="pill">Situations complexes</span>
                <span class="pill">Charge administrative</span>
                <span class="pill">Suivi difficile</span>
            </div>
        </div>
    </section>

    <!-- SPLIT (IMAGE + TEXTE) -->
    <section class="py-5">
        <div class="container split">
            <div class="text">
                <h2>Un accompagnement adapté</h2>
                <p>
                    J’interviens auprès des associations pour soutenir leurs actions,
                    accompagner les bénéficiaires et structurer les parcours.
                </p>

                <ul>
                    <li>✔ Suivi individualisé</li>
                    <li>✔ Aide administrative</li>
                    <li>✔ Actions concrètes terrain</li>
                </ul>
            </div>

            <div class="image">
                <img src="images/associations.jpg" alt="Association travail social">
            </div>
        </div>
    </section>

    <!-- INTERVENTIONS -->
    <section class="py-5 section-light">
        <div class="container text-center">
            <h2 class="mb-5">Mes interventions</h2>

            <div class="cards-container">
                <div class="card-pro">
                    <div class="icon">👤</div>
                    <h3>Accompagnement individuel</h3>
                    <p>Soutien personnalisé des bénéficiaires</p>
                </div>

                <div class="card-pro">
                    <div class="icon">📄</div>
                    <h3>Démarches administratives</h3>
                    <p>Aide aux dossiers et aux droits</p>
                </div>

                <div class="card-pro">
                    <div class="icon">👥</div>
                    <h3>Actions collectives</h3>
                    <p>Ateliers et prévention</p>
                </div>

                <div class="card-pro">
                    <div class="icon">🔗</div>
                    <h3>Orientation</h3>
                    <p>Mise en relation avec les partenaires</p>
                </div>
            </div>
        </div>
    </section>

    <!-- BÉNÉFICES -->
    <section class="py-5 text-center">
        <div class="container">
            <h2 class="mb-4">Ce que cela vous apporte</h2>

            <div class="pill-container">
                <span class="pill">Gain de temps</span>
                <span class="pill">Suivi renforcé</span>
                <span class="pill">Actions concrètes</span>
                <span class="pill">Meilleure coordination</span>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section text-center py-5">
        <div class="container">
            <h2>Construisons ensemble une solution adaptée</h2>
            <p>Échangeons sur vos besoins et vos projets</p>
            <a href="{{path('app_contact')}}" class="btn btn-light btn-lg">Nous contacter</a>
        </div>
    </section>

</div>
{% endblock %} 
