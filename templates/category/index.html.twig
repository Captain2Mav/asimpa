{% extends 'base.html.twig' %}

{% block title %}Forum{% endblock %}
{% block body %}
<h1>Forum d'échange</h1>
<p>Un espace pour vos questions et partager vos expériences</p>

<div class="row justify-content-center">
{% for category in categories %}
<div class="col-md-6 mb-4">
<div class="card">
<div class="card-body text-center">
<h2>{{category.name}}</h2>
<p>Maintien de l'emploi, difficultés de l'emploi</p>

<a href="{{ path ('app_category_show', 
{'id': category.id})  }}" class="btn btn-primary">
Voir les discussions
 
</a>
</div>
</div>
</div>

{% endfor %}

{% endblock %}
