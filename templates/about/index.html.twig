{% extends 'base.html.twig' %}

{% block title %}Qui suis-je ?{% endblock %}

{% block body %}

<div class="container mt-5">

    
    <h1 class="text-center mb-4">Qui suis-je ?</h1>

   
    <div class="text-center mb-5">
        <h2>MINDOULI PEGUY</h2>
        <p class="lead">
            Consultante sociale indépendante, spécialisée dans l'accompagnement
            des personnes en difficulté.
        </p>
    </div>

   
    <section class="mb-5">
        <h3>Mon parcours</h3>
        <p>
            Diplômée d'État, j'accompagne depuis plus de 16 ans des personnes
            dans leur parcours de vie. Mon expérience en milieu hospitalier
            et social m’a permis de développer une approche humaine et adaptée.
        </p>
    </section>

    <!-- Public -->
    <section class="mb-5">
        <h3>Quel type de public ai-je pris en charge</h3>
        <ul>
            <li>Enfants et adultes en situation de handicap</li>
            <li>Personnes âgées en perte d’autonomie</li>
            <li>Familles en difficulté</li>
            <li>Personnes en demande d’asile</li>
            <li>Victimes de violences</li>
        </ul>
    </section>

    <!-- Compétences -->
    <section class="mb-5">
        <h3>Mes compétences</h3>
        <ul>
            <li>Accompagnement social personnalisé</li>
            <li>Gestion du stress</li>
            <li>Prévention des risques psychosociaux</li>
            <li>Accompagnement fin de vie</li>
        </ul>
    </section>

    <!-- Différenciation -->
    <section class="mb-5">
        <h3>Mon atout</h3>
        <p>
            Je suis également praticienne en sophrologie, ce qui me permet
            d’accompagner mes bénéficiaires vers un mieux-être global.
        </p>
    </section>

</div>

{% endblock %} 
