{% extends 'base.html.twig' %}

{% block title %}Admin - Messages{% endblock %}

{% block body %}
<div style="padding:20px;">

    <h1 style="margin-bottom:20px;">📩 Messages reçus</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Email</th>
                <th>Message</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for contact in contacts %}
            <tr>
                <td>{{ contact.firstName }} {{ contact.lastName }}</td>
                <td>{{ contact.email }}</td>
                <td>{{ contact.message|slice(0, 40) }}...</td>
                <td>{{ contact.createdAt ? contact.createdAt|date('d/m/Y H:i') : '' }}</td>
                <td>
                    <a href="{{ path('app_admin_contact_show', {'id': contact.id}) }}">👁️</a>
                    <a href="{{ path('app_admin_contact_edit', {'id': contact.id}) }}">✏️</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun message</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

</div>
{% endblock %} 