{% extends 'base.html.twig' %}

{% block title %}Posts{% endblock %}

{% block body %}

<h1>{{post.title}}</h1>
<p>{{post.content}}</p>

  {% if is_granted('(ROLE_ADMIN)') %}
  <a href="{{path('app_post_edit', {'id': post.id}) }}">
  Modifier
  </a>

    <form action="{{ path('app_post_delete', {'id': post.id}) }}" method="POST">
        <input type="hidden" name="_token" value="{{ csrf_token('delete-post-' ~ post.id) }}">

         <button type="submit">Supprimer</button>
    </form>
    {% endif %}

    <h4 class="mt-5">Commentaires</h4>

    {% for comment in post.comments %}
    <div class="border p-2 mb-2">
    <p>{{comment.content}}</p>
    </div>
    {% else %}
    <p>Aucun commentaire</p>
    {% endfor %}

    <div class="mt-4">
   <h4>Ajouter un commentaire</h4>

    {{ form_start(form) }}
    <div class "mb-3">
    {{form_label(form.content)}}
    {{form_widget(form.content, {'attr': {'class': 'form-control'}})}}
    </div>
    <button class="btn btn-sucess">Commenter</button>
    </div>
    {{form_end(form)}}


{% endblock %}


