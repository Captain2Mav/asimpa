{% extends 'base.html.twig' %}

{% block title %}Qui suis-je{% endblock %}

{% block body %}

<div class="about-page">
<section class="hero text-center">
    <div class="container">
        <h1>ASIMPA</h1>
        <p>Consultante sociale indépendante</p>
        <a href="{{ path('app_contact') }}" class="btn btn-light btn-lg mt-3">Prendre rendez-vous</a>
    </div>
</section>

<section class="about container text-center">
    <h2>Un accompagnement humain et personnalisé</h2>
    <p class="lead">
        J'accompagne depuis plus de 16 ans des personnes dans leur parcours de vie,
        avec une approche basée sur l'écoute, la compréhension et l'adaptation.
    </p>

    <div class="row mt-5 g-4">

        <div class="col-md-4">
            <div class="card-custom">
                <div class="icon">💼</div>
                <h4>Expérience</h4>
                <p>+ 16 ans dans le social et le milieu hospitalier</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-custom">
                <div class="icon">👥</div>
                <h4>Public</h4>
                <p>Handicap, personnes âgées, familles, demandeurs d'asile</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card-custom">
                <div class="icon">🧠</div>
                <h4>Compétences</h4>
                <p>Accompagnement, stress, prévention, fin de vie</p>
            </div>
        </div>

    </div>
</section>

<section class="highlight">
    <div class="container text-center">
        <h2>Mon atout</h2>
        <p>
            Praticienne en sophrologie, j'apporte une approche globale
            pour un mieux-être durable et personnalisé.
        </p>
    </div>
</section>
</div>
{% endblock %} 
