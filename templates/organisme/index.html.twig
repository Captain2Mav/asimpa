{% extends 'base.html.twig' %}

{% block title %}Organismes{% endblock %}

{% block body_class %}page-organisme{% endblock %}

{% block body %}

<!-- HERO -->
<section class="hero-section text-white text-center">
  <div class="container">
    <h1 class="fw-bold mb-3">
      Un accompagnement social structuré pour les organismes
    </h1>

    <p class="mb-4">
      ASIMPA accompagne vos équipes face aux situations complexes avec des solutions concrètes et un suivi rigoureux.
    </p>

    <div class="hero-badges mb-4">
      <span>Confidentialité</span>
      <span>Réactivité</span>
      <span>Expertise terrain</span>
    </div>

    <a href="#" class="btn btn-light btn-lg">Échanger sur votre besoin</a>
  </div>
</section>


<!-- PROBLÉMATIQUES -->
<section class="section-cards">
    <h2>Vos réalités de terrain</h2>

    <div class="cards-container">
        <div class="card-pro">
            <div class="icon">⚠️</div>
            <h3>Situations complexes</h3>
            <p>Gestion de publics en difficulté nécessitant des réponses adaptées.</p>
        </div>

        <div class="card-pro">
            <div class="icon">📉</div>
            <h3>Parcours instables</h3>
            <p>Situations évolutives nécessitant un suivi régulier.</p>
        </div>

        <div class="card-pro">
            <div class="icon">⏱️</div>
            <h3>Manque de ressources</h3>
            <p>Des équipes sous tension face à des problématiques multiples.</p>
        </div>
    </div>
</section> 


<!-- REPONSE (LAYOUT PRO) -->
<section class="section-split py-5">
  <div class="container">
    <div class="row align-items-center g-5">

      <div class="col-md-6">
        <h2 class="fw-bold mb-4">Une réponse adaptée</h2>
        <p class="text-muted">
          ASIMPA intervient en complément de vos équipes pour structurer les situations complexes et sécuriser les parcours.
        </p>

        <ul class="list-unstyled mt-4">
          <li>✔ Intervention ciblée</li>
          <li>✔ Coordination partenaires</li>
          <li>✔ Suivi durable</li>
        </ul>
      </div>

      <div class="col-md-6">
    <div class="visual-box">
        <img src="{{ asset('images/meeting.jpg') }}" alt="Réunion équipe" class="visual-img">
    </div>
</div> 
    </div>
  </div>
</section>


<!-- INTERVENTIONS -->
<section class="py-5 bg-light">
  <div class="container text-center">
    <h2 class="fw-bold mb-5">Nos interventions</h2>

    <div class="row g-4">
      <div class="col-md-3">
        <div class="card-pro small">
          <div class="icon">👤</div>
          <h6>Accompagnement individuel</h6>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card-pro small">
          <div class="icon">📄</div>
          <h6>Démarches administratives</h6>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card-pro small">
          <div class="icon">👥</div>
          <h6>Actions collectives</h6>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card-pro small">
          <div class="icon">🔗</div>
          <h6>Coordination</h6>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- METHODE -->
<section class="py-5">
  <div class="container text-center">
    <h2 class="fw-bold mb-5">Notre méthode</h2>

    <div class="steps">
      <div class="step">Analyse</div>
      <div class="step">Diagnostic</div>
      <div class="step">Intervention</div>
      <div class="step">Suivi</div>
    </div>
  </div>
</section>


<!-- CTA FINAL -->
<section class="cta-section text-center">
  <div class="container">
    <h2 class="mb-3">Construisons une solution adaptée</h2>
    <p class="mb-4">Échangeons ensemble sur vos besoins de terrain</p>
    <a href="{{path('app_contact')}}" class="btn btn-light btn-lg">Nous contacter</a>
  </div>
</section>

{% endblock %} 
