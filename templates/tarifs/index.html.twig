{% extends 'base.html.twig' %}

{% block title %}Les Tarifs{% endblock %}

{% block body %}
<section class="tarifs-section tarifs-page">
    <div class="container text-center">
        <h2 class="mb-3 fade-in">Les Tarifs</h2>
        <p class="tarifs-intro fade-in delay-1">
            Une tarification claire, flexible et adaptée à vos besoins, pour un accompagnement personnalisé.
        </p>

        <div class="row g-4 justify-content-center">
            <div class="col-md-6 fade-in delay-1">
                <div class="tarif-card text-start">
                    <div class="tarif-icon">
                        <i class="bi bi-cash-coin"></i>
                    </div>
                    <h3>Tarification flexible</h3>
                    <p>Possibilité de paiement à l’heure ou au forfait selon votre situation.</p>
                </div>
            </div>

            <div class="col-md-6 fade-in delay-2">
                <div class="tarif-card text-start">
                    <div class="tarif-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3>Transparence</h3>
                    <p>Les tarifs sont présentés de manière claire pour garantir un service de qualité et personnalisé.</p>
                </div>
            </div>
        </div>

        <div class="cta-tarifs fade-in delay-3">
            <a href="{{path('app_contact')}}" class="btn">Demander un devis</a>
        </div>
    </div>
</section> 

{% endblock %}
