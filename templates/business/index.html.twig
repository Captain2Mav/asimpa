{% extends 'base.html.twig' %}

{% block title %}Entreprises{% endblock %}

{% block body %}

<div class="page-entreprise">

<!-- HERO -->
<section class="hero-section bg-primary text-white text-center py-5">
  <div class="container">
    <h1 class="fw-bold mb-3">
      Un accompagnement social au service des salariés
    </h1>
    <p class="mb-4">
      Améliorez le bien-être au travail et accompagnez vos équipes face aux situations complexes.
    </p>
    <a href="#" class="btn btn-light btn-lg">Prendre contact</a>
  </div>
</section>

<!-- ENJEUX -->
<section class="section-light py-5 text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">Des enjeux humains et professionnels</h2>

    <div class="pill-container">
      <div class="pill">⚠️ Salariés en difficulté</div>
      <div class="pill">📉 Baisse de performance</div>
      <div class="pill">😓 Stress et risques</div>
      <div class="pill">⚖️ Obligations légales</div>
    </div>
  </div>
</section>

<!-- ACCOMPAGNEMENT + IMAGE -->
<section class="section-split py-5">
  <div class="container split">
   
    <div class="text">
      <h2 class="fw-bold mb-3">Un accompagnement social externalisé</h2>

      <ul>
        <li>Interlocuteur unique dédié</li>
        <li>Suivi continu des situations</li>
        <li>Approche confidentielle et humaine</li>
        <li>Solutions concrètes et durables</li>
      </ul>
    </div>

    <div class="image">
      <img src="/images/accompagnement.jpg" alt="Accompagnement professionnel">
    </div>

  </div>
</section>

<!-- DOMAINES -->
<section class="section-light py-5 text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">Domaines d'intervention</h2>

    <div class="cards-container">
      <div class="card-pro">
        <div class="icon">💼</div>
        <h3>Vie professionnelle</h3>
        <p>Maintien dans l'emploi, prévention des risques psychosociaux, accompagnement des situations sensibles.</p>
      </div>

      <div class="card-pro">
        <div class="icon">🏠</div>
        <h3>Vie personnelle</h3>
        <p>Logement, budget, difficultés familiales, accompagnement administratif.</p>
      </div>
    </div>
  </div>
</section>

<!-- BENEFICES -->
<section class="section-light py-5 text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">Des bénéfices concrets</h2>

    <div class="pill-container">
      <div class="pill">⏱ Gain de temps</div>
      <div class="pill">😌 Moins de stress</div>
      <div class="pill">📈 Meilleure performance</div>
      <div class="pill">🤝 Climat social amélioré</div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section text-center py-5">
  <div class="container">
    <h2 class="fw-bold mb-3">Mettez en place un accompagnement adapté</h2>
    <p class="mb-4">Échangeons sur vos besoins et construisons une solution adaptée à votre entreprise.</p>
    <a href="{{path('app_contact')}}" class="btn btn-light btn-lg">Prendre contact</a>
  </div>
</section>

</div>

{% endblock %} 
