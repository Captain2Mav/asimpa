{% extends 'base.html.twig' %}

{% block title %}Pourquoi faire appel ?{% endblock %}

{% block body %}
<div class="why-page">

    <section class="why-hero">
        <div class="container">
            <span class="why-badge">Pourquoi faire appel à ASIMPA ?</span>
            <h1>Des situations difficiles à gérer seul</h1>
            <p class="why-intro">
                Quand les démarches deviennent lourdes, floues ou épuisantes,
                un accompagnement clair et humain permet de retrouver des repères.
            </p>
        </div>
    </section>

    <section class="why-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="why-card fade-in">
                        <h2>Problèmes</h2>
                        <ul class="why-list">
                            <li>Difficulté à trouver les bons interlocuteurs</li>
                            <li>Démarches longues et complexes</li>
                            <li>Manque d’informations</li>
                            <li>Multiplication des services</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="why-card fade-in delay-1">
                        <h2>Ressenti</h2>
                        <ul class="why-list">
                            <li>Perte de repères</li>
                            <li>Fatigue administrative</li>
                            <li>Peur du jugement</li>
                            <li>Abandon des démarches</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="why-section">
        <div class="container text-center">
            <h2 class="section-title fade-in">Ce que vous recherchez</h2>
            <div class="pill-grid fade-in delay-1">
                <div class="why-pill">Écoute</div>
                <div class="why-pill">Rapidité</div>
                <div class="why-pill">Clarté</div>
                <div class="why-pill">Suivi personnalisé</div>
            </div>
        </div>
    </section>

    <section class="why-section">
        <div class="container text-center">
            <h2 class="section-title fade-in">Une solution adaptée</h2>
            <div class="row g-4 mt-2">
                <div class="col-md-3 col-sm-6">
                    <div class="mini-card fade-in">
                        <div class="mini-icon">👤</div>
                        <p>Un interlocuteur unique</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="mini-card fade-in delay-1">
                        <div class="mini-icon">🤝</div>
                        <p>Accompagnement personnalisé</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="mini-card fade-in delay-2">
                        <div class="mini-icon">📄</div>
                        <p>Démarches simplifiées</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="mini-card fade-in delay-3">
                        <div class="mini-icon">📌</div>
                        <p>Suivi structuré</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div> 

{% endblock %} 
